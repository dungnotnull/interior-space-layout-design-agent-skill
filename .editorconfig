# EditorConfig - keeps the repo consistent across editors/OSes.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{md}]
trim_trailing_whitespace = false

[*.{py}]
indent_size = 4
max_line_length = 100

[*.{yml,yaml,toml}]
indent_size = 2
